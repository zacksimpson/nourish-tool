{
  "expo": {
    "name": "Nourish",
    "slug": "nourish-tool",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "nourish",
    "icon": "./assets/images/icon.png",
    "android": {
      "backgroundColor": "#000000",
      "package": "com.zacksimpson.nourish",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/PublicSans-Regular.ttf",
            "./assets/fonts/PublicSans-Thin.ttf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#000000",
          "androidMode": "default"
        }
      ],
      "./plugins/withAndroidConfigChanges",
      "./plugins/withAndroidTheme",
      "./plugins/withDebugApplicationIdSuffix"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7a9a2040-b4a5-4c3d-b087-28cf3c153ae2"
      }
    }
  }
}
