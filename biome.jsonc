{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "javascript": {
    "globals": ["GestureHandlerRootView"]
  },
  "linter": {
    "rules": {
      "style": {
        "useFilenamingConvention": {
          "options": {
            "filenameCases": ["camelCase", "PascalCase"]
          }
        }
      }
    }
  }
}
